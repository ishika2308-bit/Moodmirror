# Firebase Project
FIREBASE_PROJECT_ID=your-project-id

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# AES Encryption — 32-byte hex key (generate with: openssl rand -hex 32)
AES_ENCRYPTION_KEY=your-64-char-hex-key-here

# AES IV Salt (generate with: openssl rand -hex 16)
AES_IV_SECRET=your-32-char-hex-iv-salt-here

# PII Tokenization secret
TOKENIZER_SECRET=your-tokenizer-secret-here

# Rate Limiting (requests per window)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
